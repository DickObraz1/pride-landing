# Ecomail API key — Ecomail dashboard → Nastavení → API
ECOMAIL_API_KEY=your_api_key_here

# Ecomail list ID — "ENG PRIDE" list = 21
ECOMAIL_LIST_ID=21

# Přesný kód custom fieldu pro gender (vytvořit v Ecomailu → Vlastní pole)
# TODO: doplň po vytvoření custom fieldu v Ecomailu
ECOMAIL_GENDER_FIELD=gender

# URL zásad zpracování osobních údajů (pro GDPR checkbox)
# TODO: doplň skutečnou URL
NEXT_PUBLIC_PRIVACY_URL=https://dickobraz.cz/privacy
